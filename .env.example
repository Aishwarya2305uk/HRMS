# Copy this file to .env.local and fill in real values. .env.local is
# gitignored — never commit real secrets.

# MongoDB Atlas (or any MongoDB) connection string.
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>/?retryWrites=true&w=majority

# Long random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Optional — defaults to 7d.
JWT_EXPIRES_IN=7d

# The ONE account the app creates on its own, the first time it connects to
# an empty database. Sign in with these, then add every other employee and
# manager from the People screen — never edit these to "reset" the admin
# later, they only take effect while no matching account exists yet.
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# Optional — if set, the daily attendance-finalizer cron endpoint
# (/api/cron/finalize) requires this as a Bearer token.
CRON_SECRET=
